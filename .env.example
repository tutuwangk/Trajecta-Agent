LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-v4-flash
# Optional: LLM_PLANNING_MODEL=deepseek-v4-flash
# Optional: LLM_COPY_MODEL=deepseek-v4-flash
# Optional: LLM_DURATION_MODEL=deepseek-v4-flash
# DeepSeek V4 规划默认显式开启 thinking，文案和资料解析默认关闭。
# Optional: LLM_THINKING=false
# Optional: LLM_PLANNING_THINKING=true
# Optional: LLM_COPY_THINKING=false
# Optional: LLM_DURATION_THINKING=false
# Optional: LLM_PLANNING_REASONING_EFFORT=high
# Optional: LLM_TRUST_ENV=false
# Optional: LLM_MAX_RETRIES=2
# Optional: LLM_MAX_TOKENS=8192
# Optional: LLM_PLANNING_MAX_TOKENS=16384
# Optional: LLM_COPY_MAX_TOKENS=4096
# Optional: LLM_DURATION_MAX_TOKENS=4096
# 规划 JSON 截断后允许单次扩大的上限。
# Optional: LLM_MAX_OUTPUT_TOKENS=32768
# Optional: LLM_READ_TIMEOUT_SECONDS=650
AMAP_API_KEY=your_amap_web_service_key
# Optional: DATABASE_PATH=data/travel_agent.sqlite3
# Optional: CORS_ORIGINS=http://localhost:3000
# Required for cross-machine or cloud deployment of the frontend:
# BACKEND_API_BASE_URL=https://your-backend-host
